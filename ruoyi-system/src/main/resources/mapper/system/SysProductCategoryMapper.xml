<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysProductCategoryMapper">

    <resultMap type="com.ruoyi.common.core.domain.entity.SysProductCategory" id="SysProductCategoryResult">
        <id property="categoryId" column="category_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="orderNum" column="order_num"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectCategoryVo">
        select category_id, parent_id, category_name, order_num, status, create_by, create_time, update_by, update_time, remark
        from sys_product_category
    </sql>

    <select id="selectCategoryList" parameterType="com.ruoyi.common.core.domain.entity.SysProductCategory" resultMap="SysProductCategoryResult">
        <include refid="selectCategoryVo"/>
        where del_flag = '0'
        <if test="categoryName != null and categoryName != ''">
            AND category_name like concat('%', #{categoryName}, '%')
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        order by parent_id, order_num
    </select>

    <select id="selectCategoryAll" resultMap="SysProductCategoryResult">
        <include refid="selectCategoryVo"/>
        where del_flag = '0'
        order by parent_id, order_num
    </select>

    <select id="selectCategoryTreeList" resultMap="SysProductCategoryResult">
        select category_id, parent_id, category_name, order_num, status, create_by, create_time, update_by, update_time, remark
        from sys_product_category
        where del_flag = '0'
        order by parent_id, order_num
    </select>

    <select id="selectCategoryById" parameterType="Long" resultMap="SysProductCategoryResult">
        <include refid="selectCategoryVo"/>
        where category_id = #{categoryId}
    </select>

    <select id="checkCategoryNameUnique" resultMap="SysProductCategoryResult">
        <include refid="selectCategoryVo"/>
        where parent_id = #{parentId} and category_name = #{categoryName} and del_flag = '0'
    </select>

    <select id="checkExistChildCategory" resultType="int">
        select count(1) from sys_product_category where parent_id = #{categoryId} and del_flag = '0'
    </select>

    <select id="checkExistProduct" resultType="int">
        select count(1) from sys_product where category_id = #{categoryId} and del_flag = '0'
    </select>

    <insert id="insertCategory" parameterType="com.ruoyi.common.core.domain.entity.SysProductCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into sys_product_category(
            <if test="categoryId != null and categoryId != 0">category_id,</if>
            <if test="parentId != null and parentId != 0">parent_id,</if>
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        )values(
            <if test="categoryId != null and categoryId != 0">#{categoryId},</if>
            <if test="parentId != null and parentId != 0">#{parentId},</if>
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateCategory" parameterType="com.ruoyi.common.core.domain.entity.SysProductCategory">
        update sys_product_category
        <set>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <delete id="deleteCategoryById" parameterType="Long">
        update sys_product_category set del_flag = '1' where category_id = #{categoryId}
    </delete>

</mapper>
